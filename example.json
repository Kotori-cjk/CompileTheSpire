            "spaces":{
                "space1":{
                    "type":"prefix",
                    "val":"block"
                },
                "space2":{
                    "type":"find",
                    "val":"block"
                }
            }
        }
    },
    "boss":{
        "code":"$space1$\n$space2$\nint main(){\n\tint a;\n\tcin>>a;\n\tA obj(a);\n\tobj.print();\n\treturn 0;\n}",
        "input":"1",
        "output":"5",
        "spaces":{
            "space1":{
                "type":"match",
                "val":["func_ret[block_ret_loc]"]
            },
            "space2":{
                "type":"match",
                "val":["class_calc[block_add1,block_mul2]"]
            }
        }
    },
    "end_text":"&是取地址,*是解引用"
